# ── Requis ────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Optionnel (valeurs par défaut indiquées) ──────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-6
MAX_TURNS=10
MIN_TURNS=3
CONVERGENCE_THRESHOLD=0.92
FLATLINE_TURNS=3
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2